# Kopiér til .env og fyll inn verdier

# PostgreSQL – hentes automatisk fra Railway hvis du linker databasen
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Hemmelighet for å beskytte API-et ditt
# Generer med: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=bytt_meg_ut_med_noe_tilfeldig

# Port (Railway setter denne automatisk)
PORT=3001

# Tillatte origins for CORS (din Vercel-URL)
ALLOWED_ORIGINS=http://localhost:5173,https://din-app.vercel.app
